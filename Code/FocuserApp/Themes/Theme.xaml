<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

  <!-- ============ Color palette ============ -->
  <Color x:Key="BgColor">#FF0B0E13</Color>
  <Color x:Key="Bg2Color">#FF11151C</Color>
  <Color x:Key="PanelColor">#FF151A22</Color>
  <Color x:Key="Panel2Color">#FF1A2029</Color>
  <Color x:Key="PanelHiColor">#FF1F2632</Color>
  <Color x:Key="LineColor">#FF252C38</Color>
  <Color x:Key="Line2Color">#FF2C3441</Color>
  <Color x:Key="TextColor">#FFE6E8EC</Color>
  <Color x:Key="Text2Color">#FFAAB1BD</Color>
  <Color x:Key="Text3Color">#FF7A818D</Color>
  <Color x:Key="Text4Color">#FF5B626D</Color>
  <Color x:Key="AccentColor">#FFE5484D</Color>
  <Color x:Key="Accent2Color">#FFFF5A5F</Color>
  <Color x:Key="AccentSoftColor">#1FE5484D</Color>
  <Color x:Key="AccentLineColor">#59E5484D</Color>
  <Color x:Key="GoodColor">#FF3ECF8E</Color>
  <Color x:Key="WarnColor">#FFF5A524</Color>
  <Color x:Key="BadColor">#FFE5484D</Color>

  <!-- ============ Brushes ============ -->
  <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BgColor}" />
  <SolidColorBrush x:Key="Bg2Brush" Color="{StaticResource Bg2Color}" />
  <SolidColorBrush x:Key="PanelBrush" Color="{StaticResource PanelColor}" />
  <SolidColorBrush x:Key="Panel2Brush" Color="{StaticResource Panel2Color}" />
  <SolidColorBrush x:Key="PanelHiBrush" Color="{StaticResource PanelHiColor}" />
  <SolidColorBrush x:Key="LineBrush" Color="{StaticResource LineColor}" />
  <SolidColorBrush x:Key="Line2Brush" Color="{StaticResource Line2Color}" />
  <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" />
  <SolidColorBrush x:Key="Text2Brush" Color="{StaticResource Text2Color}" />
  <SolidColorBrush x:Key="Text3Brush" Color="{StaticResource Text3Color}" />
  <SolidColorBrush x:Key="Text4Brush" Color="{StaticResource Text4Color}" />
  <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
  <SolidColorBrush x:Key="AccentSoftBrush" Color="{StaticResource AccentSoftColor}" />
  <SolidColorBrush x:Key="AccentLineBrush" Color="{StaticResource AccentLineColor}" />
  <SolidColorBrush x:Key="GoodBrush" Color="{StaticResource GoodColor}" />
  <SolidColorBrush x:Key="WarnBrush" Color="{StaticResource WarnColor}" />

  <!-- Card / titlebar gradients -->
  <LinearGradientBrush x:Key="CardHeaderBrush" StartPoint="0,0" EndPoint="0,1">
    <GradientStop Color="#FF181D26" Offset="0" />
    <GradientStop Color="#FF141923" Offset="1" />
  </LinearGradientBrush>

  <LinearGradientBrush x:Key="TitleBarBrush" StartPoint="0,0" EndPoint="0,1">
    <GradientStop Color="#FF161B24" Offset="0" />
    <GradientStop Color="#FF11151C" Offset="1" />
  </LinearGradientBrush>

  <LinearGradientBrush x:Key="ConsoleHeaderBrush" StartPoint="0,0" EndPoint="0,1">
    <GradientStop Color="#FF10141B" Offset="0" />
    <GradientStop Color="#FF0C0F15" Offset="1" />
  </LinearGradientBrush>

  <LinearGradientBrush x:Key="PrimaryButtonBrush" StartPoint="0,0" EndPoint="0,1">
    <GradientStop Color="#FFEC4F53" Offset="0" />
    <GradientStop Color="#FFD83A3F" Offset="1" />
  </LinearGradientBrush>

  <LinearGradientBrush x:Key="PrimaryButtonHoverBrush" StartPoint="0,0" EndPoint="0,1">
    <GradientStop Color="#FFF15A5E" Offset="0" />
    <GradientStop Color="#FFDC4045" Offset="1" />
  </LinearGradientBrush>

  <LinearGradientBrush x:Key="ProgressFillBrush" StartPoint="0,0" EndPoint="1,0">
    <GradientStop Color="{StaticResource AccentColor}" Offset="0" />
    <GradientStop Color="#FFFF7A7E" Offset="1" />
  </LinearGradientBrush>

  <RadialGradientBrush x:Key="WindowBackgroundBrush"
                       Center="0.2,0" GradientOrigin="0.2,0"
                       RadiusX="1.0" RadiusY="0.7" MappingMode="RelativeToBoundingBox">
    <GradientStop Color="#FF14202D" Offset="0" />
    <GradientStop Color="{StaticResource BgColor}" Offset="0.7" />
  </RadialGradientBrush>

  <!-- Logo gradient -->
  <RadialGradientBrush x:Key="LogoGradient" Center="0.3,0.3" GradientOrigin="0.3,0.3" RadiusX="0.9" RadiusY="0.9">
    <GradientStop Color="#FFFF7A7E" Offset="0" />
    <GradientStop Color="{StaticResource AccentColor}" Offset="0.55" />
    <GradientStop Color="#FF7A1A1C" Offset="1" />
  </RadialGradientBrush>

  <!-- ============ Typography ============ -->
  <FontFamily x:Key="SansFont">Inter</FontFamily>
  <FontFamily x:Key="MonoFont">JetBrains Mono</FontFamily>

  <!-- ============ Drop shadows ============ -->
  <DropShadowEffect x:Key="WindowShadow" BlurRadius="24" ShadowDepth="6" Opacity="0.45" Direction="270" />
  <DropShadowEffect x:Key="PrimaryGlow" BlurRadius="12" ShadowDepth="0" Opacity="0.45" Color="{StaticResource AccentColor}" />

  <!-- ============ Common values ============ -->
  <CornerRadius x:Key="CardRadius">10</CornerRadius>
  <CornerRadius x:Key="ButtonRadius">7</CornerRadius>
  <CornerRadius x:Key="WindowRadius">14</CornerRadius>

  <sys:Double x:Key="InputHeight">30</sys:Double>
  <sys:Double x:Key="ButtonHeight">30</sys:Double>
</ResourceDictionary>
