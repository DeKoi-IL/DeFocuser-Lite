<Window x:Class="ASCOM.DeKoi.DeFocuserApp.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="520" Height="520"
        MinWidth="420" MinHeight="380"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="CanResize" ShowInTaskbar="False"
        FontFamily="{StaticResource SansFont}" FontSize="13"
        Foreground="{StaticResource TextBrush}"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True">

  <WindowChrome.WindowChrome>
    <WindowChrome CaptionHeight="0" GlassFrameThickness="0" CornerRadius="0" ResizeBorderThickness="6" />
  </WindowChrome.WindowChrome>

  <Border Background="{StaticResource WindowBackgroundBrush}"
          CornerRadius="14"
          BorderBrush="{StaticResource LineBrush}"
          BorderThickness="1"
          Margin="12"
          Effect="{StaticResource WindowShadow}"
          SnapsToDevicePixels="True"
          ClipToBounds="True">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <!-- Title bar -->
      <Border Grid.Row="0"
              Background="{StaticResource TitleBarBrush}"
              BorderBrush="{StaticResource LineBrush}"
              BorderThickness="0,0,0,1"
              Padding="14,10"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <Path Data="{StaticResource Icon.Cog}" Style="{StaticResource HeaderIconPath}" />
            <TextBlock Text="Settings"
                       Foreground="{StaticResource TextBrush}"
                       FontSize="13" FontWeight="SemiBold"
                       Margin="10,0,0,0" VerticalAlignment="Center" />
          </StackPanel>

          <Button Grid.Column="1" Style="{StaticResource WindowCloseButton}"
                  Click="CloseButton_Click" ToolTip="Close">
            <Path Data="{StaticResource Icon.X}" Style="{StaticResource WinIconPath}" Width="11" Height="11" />
          </Button>
        </Grid>
      </Border>

      <!-- Body -->
      <ScrollViewer Grid.Row="1" Padding="18,18,18,0"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <StackPanel>

          <!-- Updates section -->
          <Border Background="{StaticResource PanelBrush}"
                  BorderBrush="{StaticResource LineBrush}"
                  BorderThickness="1" CornerRadius="10"
                  Padding="14" Margin="0,0,0,14">
            <StackPanel>
              <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Path Data="{StaticResource Icon.Refresh}" Style="{StaticResource HeaderIconPath}" />
                <TextBlock Text="UPDATES" Style="{StaticResource CardLabel}" Margin="9,0,0,0" />
              </StackPanel>

              <!-- Hub row -->
              <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="120" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Hub app" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Installed " Foreground="{StaticResource Text3Brush}" />
                    <TextBlock Text="{Binding HubVersionDisplay}" Foreground="{StaticResource TextBrush}"
                               FontFamily="{StaticResource MonoFont}" />
                    <TextBlock Text=" · Latest " Foreground="{StaticResource Text3Brush}" Margin="6,0,0,0" />
                    <TextBlock Text="{Binding LatestHubVersionDisplay}" Foreground="{StaticResource TextBrush}"
                               FontFamily="{StaticResource MonoFont}" />
                  </StackPanel>
                </StackPanel>
                <Button Grid.Column="2" Style="{StaticResource PrimaryButton}"
                        Content="Install update"
                        Command="{Binding InstallUpdateCommand}"
                        Visibility="{Binding HubUpdateAvailable, Converter={StaticResource BoolToVis}}" />
              </Grid>

              <!-- Firmware row -->
              <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="120" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Firmware" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Device " Foreground="{StaticResource Text3Brush}" />
                    <TextBlock Text="{Binding FirmwareVersionDisplay}" Foreground="{StaticResource TextBrush}"
                               FontFamily="{StaticResource MonoFont}" />
                    <TextBlock Text=" · Latest " Foreground="{StaticResource Text3Brush}" Margin="6,0,0,0" />
                    <TextBlock Text="{Binding LatestFirmwareVersionDisplay}" Foreground="{StaticResource TextBrush}"
                               FontFamily="{StaticResource MonoFont}" />
                  </StackPanel>
                </StackPanel>
                <Button Grid.Column="2" Style="{StaticResource SmButton}"
                        Content="Update firmware"
                        Command="{Binding FlashFirmwareCommand}"
                        Visibility="{Binding FirmwareUpdateAvailable, Converter={StaticResource BoolToVis}}" />
              </Grid>

              <Border Height="1" Background="{StaticResource LineBrush}" Margin="-14,4,-14,12" />

              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                  <TextBlock Text="{Binding Status}" Foreground="{StaticResource Text2Brush}" />
                  <TextBlock Text="{Binding LastCheckedDisplay}" Foreground="{StaticResource Text3Brush}"
                             FontSize="11.5" Margin="0,2,0,0" />
                </StackPanel>
                <Button Grid.Column="1" Style="{StaticResource SmButton}"
                        Content="Check for updates"
                        Command="{Binding CheckForUpdatesCommand}" />
              </Grid>
            </StackPanel>
          </Border>

          <!-- Placeholder for future sections (advanced settings, theme, etc.) -->

        </StackPanel>
      </ScrollViewer>

      <!-- Footer -->
      <Border Grid.Row="2"
              Background="{StaticResource TitleBarBrush}"
              BorderBrush="{StaticResource LineBrush}"
              BorderThickness="0,1,0,0"
              Padding="14,10">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
          <Button Style="{StaticResource SmButton}" Content="Close" Click="CloseButton_Click" />
        </StackPanel>
      </Border>
    </Grid>
  </Border>
</Window>
