<Window x:Class="ASCOM.DeKoi.DeFocuserApp.Views.UpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update available"
        Width="540" Height="500"
        MinWidth="420" MinHeight="320"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="CanResize" ShowInTaskbar="False"
        FontFamily="{StaticResource SansFont}" FontSize="13"
        Foreground="{StaticResource TextBrush}"
        UseLayoutRounding="True">

  <WindowChrome.WindowChrome>
    <WindowChrome CaptionHeight="0" GlassFrameThickness="0" CornerRadius="0" ResizeBorderThickness="6" />
  </WindowChrome.WindowChrome>

  <Border Background="{StaticResource WindowBackgroundBrush}"
          CornerRadius="14"
          BorderBrush="{StaticResource LineBrush}"
          BorderThickness="1"
          Margin="12"
          Effect="{StaticResource WindowShadow}"
          SnapsToDevicePixels="True"
          ClipToBounds="True">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <!-- Title bar -->
      <Border Grid.Row="0"
              Background="{StaticResource TitleBarBrush}"
              BorderBrush="{StaticResource LineBrush}"
              BorderThickness="0,0,0,1"
              Padding="14,10"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <Path Data="{StaticResource Icon.Refresh}" Style="{StaticResource HeaderIconPath}" />
            <TextBlock Text="Update available"
                       Foreground="{StaticResource TextBrush}"
                       FontSize="13" FontWeight="SemiBold"
                       Margin="10,0,0,0" VerticalAlignment="Center" />
          </StackPanel>
          <Button Grid.Column="1" Style="{StaticResource WindowCloseButton}"
                  Click="CloseButton_Click" ToolTip="Close">
            <Path Data="{StaticResource Icon.X}" Style="{StaticResource WinIconPath}" Width="11" Height="11" />
          </Button>
        </Grid>
      </Border>

      <!-- Heading -->
      <StackPanel Grid.Row="1" Margin="18,16,18,8">
        <TextBlock x:Name="HeadingText"
                   FontSize="18" FontWeight="SemiBold"
                   Foreground="{StaticResource TextBrush}" />
        <TextBlock x:Name="SubHeadingText"
                   FontSize="12" Foreground="{StaticResource Text3Brush}"
                   Margin="0,2,0,0" />
      </StackPanel>

      <!-- Release notes -->
      <Border Grid.Row="2" Margin="18,4,18,12"
              Background="{StaticResource PanelBrush}"
              BorderBrush="{StaticResource LineBrush}"
              BorderThickness="1" CornerRadius="10"
              SnapsToDevicePixels="True">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14,10">
          <TextBlock x:Name="ReleaseNotesText"
                     TextWrapping="Wrap"
                     FontFamily="{StaticResource MonoFont}"
                     FontSize="12"
                     Foreground="{StaticResource Text2Brush}" />
        </ScrollViewer>
      </Border>

      <!-- Footer -->
      <Border Grid.Row="3"
              Background="{StaticResource TitleBarBrush}"
              BorderBrush="{StaticResource LineBrush}"
              BorderThickness="0,1,0,0"
              Padding="14,10">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <Button Style="{StaticResource XsButton}" Content="Skip this version"
                  Click="Skip_Click" />

          <TextBlock Grid.Column="1" x:Name="StatusText"
                     VerticalAlignment="Center" HorizontalAlignment="Center"
                     Foreground="{StaticResource Text3Brush}" />

          <StackPanel Grid.Column="2" Orientation="Horizontal">
            <Button Style="{StaticResource SmButton}" Content="Later" Click="CloseButton_Click" Margin="0,0,8,0" />
            <Button x:Name="InstallButton" Style="{StaticResource PrimaryButton}"
                    Content="Install now" Click="Install_Click" />
          </StackPanel>
        </Grid>
      </Border>
    </Grid>
  </Border>
</Window>
